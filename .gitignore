validation/realworld/
expenses-eval/
*.pii.json
*.pii.txt

# Local agent + tooling scratch (worktrees, MCP browser snapshots) -- never commit
.claude/
.playwright-mcp/

# Appliance runtime data + artifacts (egress proxy -- never commit)
