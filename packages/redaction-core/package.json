{
  "name": "@ossredact/core",
  "version": "0.2.0",
  "description": "Tier-0 deterministic PII detector and span/redaction core for OSSRedact. Pure TypeScript, browser-safe, zero runtime dependencies.",
  "license": "MIT",
  "author": "ZenSystemAI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZenSystemAI/OSSRedact.git",
    "directory": "packages/redaction-core"
  },
  "homepage": "https://github.com/ZenSystemAI/OSSRedact/tree/main/packages/redaction-core#readme",
  "bugs": "https://github.com/ZenSystemAI/OSSRedact/issues",
  "keywords": [
    "pii",
    "redaction",
    "privacy",
    "anonymization",
    "ner",
    "gdpr",
    "detector",
    "typescript",
    "browser"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "esbuild": "0.27.2"
  }
}
