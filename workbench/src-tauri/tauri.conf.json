{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OSSRedact",
  "version": "0.1.0",
  "identifier": "dev.ossredact.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "OSSRedact -- Firewall Console",
        "width": 440,
        "height": 640,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "skipTaskbar": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Tray-resident PII firewall console",
    "longDescription": "OSSRedact firewall console -- a tray-resident native shell over the local OSSRedact egress daemon. Pop open the small window to inspect live redaction activity, edit the allowlist, and check firewall health. The redaction daemon runs as a separate long-lived service; this app connects to it on 127.0.0.1:8011."
  }
}
